<div>
  <video
    src="{{ src }}"
    controls
    {% if width %}
        width="{{ width }}"
    {% endif %}
    {% if height %}
        height="{{ height }}"
    {% endif %}
    {% if poster %}
        poster="{{ poster }}"
    {% endif %}
    {% if autoplay %}
        autoplay
    {% endif %}
    {% if muted %}
        muted
    {% endif %}
    {% if loop %}
        loop
    {% endif %}
  >
    Your browser does not support the video tag.
  </video>
</div>
